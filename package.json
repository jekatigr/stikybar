{
  "name": "stickybar",
  "version": "0.6.1",
  "description": "Configurable two-line status bar and fixed editor extension for pi coding agent",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "*.md",
    "*.json",
    "!progress.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "stickybar",
    "status-bar",
    "extension"
  ],
  "license": "MIT",
  "scripts": {
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
